(pcb router-intent-refiner-pair-unrelated-copper
  (parser (string_quote "))
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu (type signal) (property (index 0)))
    (layer B.Cu (type signal) (property (index 1)))
    (boundary (path pcb 0  0 0  100000 0  100000 -60000  0 -60000  0 0))
    (via "Via[0-1]_600:300_um")
    (rule (width 200) (clearance 150) (clearance 100 (type smd_smd)))
  )
  (library
    (padstack Rect[T]Pad_200x200_um
      (shape (rect F.Cu -100 -100 100 100))
      (attach off)
    )
    (padstack "Via[0-1]_600:300_um"
      (shape (circle F.Cu 600))
      (shape (circle B.Cu 600))
      (attach off)
    )
    (image Pad_200um
      (pin Rect[T]Pad_200x200_um 1 0 0)
    )
  )
  (placement
    (component Pad_200um
      (place P1 10000 -20000 front 0)
      (place P2 90000 -20000 front 0)
      (place N1 10000 -20380 front 0)
      (place N2 90000 -20380 front 0)
      (place K1 40000 -35000 front 0)
      (place K2 60000 -35000 front 0)
    )
  )
  (network
    (net USB_D+ (pins P1-1 P2-1))
    (net USB_D- (pins N1-1 N2-1))
    (net KEEP (pins K1-1 K2-1))
    (class default "" USB_D+ USB_D- KEEP
      (rule (width 200) (clearance 150))
      (circuit (use_via "Via[0-1]_600:300_um") (use_layer F.Cu B.Cu))
    )
  )
  (wiring
    (wire (path F.Cu 200  10000 -20000  90000 -20000) (net USB_D+) (type route))
    (wire (path F.Cu 200  10000 -20380  25000 -20380  25000 -50000  75000 -50000  75000 -20380  90000 -20380) (net USB_D-) (type route))
    (wire (path F.Cu 200  40000 -35000  60000 -35000) (net KEEP) (type route))
  )
)
