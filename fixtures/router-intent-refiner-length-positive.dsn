(pcb router-intent-refiner-length-positive
  (parser (string_quote "))
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu (type signal) (property (index 0)))
    (layer B.Cu (type signal) (property (index 1)))
    (boundary (path pcb 0  0 0  100000 0  100000 -80000  0 -80000  0 0))
    (via "Via[0-1]_600:300_um")
    (rule (width 500) (clearance 500) (clearance 100 (type smd_smd)))
  )
  (library
    (padstack Rect[T]Pad_1000x1000_um
      (shape (rect F.Cu -500 -500 500 500))
      (shape (rect B.Cu -500 -500 500 500))
      (attach off)
    )
    (padstack "Via[0-1]_600:300_um"
      (shape (circle F.Cu 600))
      (shape (circle B.Cu 600))
      (attach off)
    )
    (image Pad_1x1mm
      (pin Rect[T]Pad_1000x1000_um 1 0 0)
    )
  )
  (placement
    (component Pad_1x1mm
      (place A1 10000 -15000 front 0)
      (place A2 90000 -15000 front 0)
      (place B1 10000 -30000 front 0)
      (place B2 90000 -30000 front 0)
      (place C1 10000 -45000 front 0)
      (place C2 90000 -45000 front 0)
    )
  )
  (network
    (net BUS_A (pins A1-1 A2-1))
    (net BUS_B (pins B1-1 B2-1))
    (net BUS_C (pins C1-1 C2-1))
    (class default "" BUS_A BUS_B BUS_C
      (rule (width 500) (clearance 500))
      (circuit (use_via "Via[0-1]_600:300_um") (use_layer F.Cu B.Cu))
    )
  )
  (wiring
    (wire (path F.Cu 500  10000 -15000  90000 -15000) (net BUS_A) (type route))
    (wire (path B.Cu 500  10000 -30000  35000 -30000  35000 -65000  65000 -65000  65000 -30000  90000 -30000) (net BUS_B) (type route))
    (wire (path F.Cu 500  10000 -45000  90000 -45000) (net BUS_C) (type route))
  )
)
