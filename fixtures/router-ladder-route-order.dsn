(pcb router-ladder-route-order
  (parser (string_quote "))
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu (type signal) (property (index 0)))
    (layer B.Cu (type signal) (property (index 1)))
    (boundary (path pcb 0  0 0  100000 0  100000 -80000  0 -80000  0 0))
    (via "Via[0-1]_600:300_um")
    (rule (width 500) (clearance 500) (clearance 100 (type smd_smd)))
  )
  (library
    (padstack Rect[T]Pad_1000x1000_um
      (shape (rect F.Cu -500 -500 500 500))
      (shape (rect B.Cu -500 -500 500 500))
      (attach off)
    )
    (padstack "Via[0-1]_600:300_um"
      (shape (circle F.Cu 600))
      (shape (circle B.Cu 600))
      (attach off)
    )
    (image Pad_1x1mm
      (pin Rect[T]Pad_1000x1000_um 1 0 0)
    )
  )
  (placement
    (component Pad_1x1mm
      (place H1 10000 -20000 front 0.000000)
      (place H2 90000 -20000 front 0.000000)
      (place M1 10000 -40000 front 0.000000)
      (place M2 90000 -40000 front 0.000000)
      (place L1 10000 -60000 front 0.000000)
      (place L2 90000 -60000 front 0.000000)
    )
  )
  (network
    (net HIGH (pins H1-1 H2-1))
    (net MEDIUM (pins M1-1 M2-1))
    (net LOW (pins L1-1 L2-1))
    (class default "" HIGH MEDIUM LOW
      (rule (width 500) (clearance 500))
      (circuit (use_via "Via[0-1]_600:300_um") (use_layer F.Cu B.Cu))
    )
  )
  (wiring)
)
